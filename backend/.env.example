# ─── Email (Gmail SMTP) ──────────────────────────────────────────────────────
# The Gmail address used to SEND notifications.
SMTP_SENDER=your-clinic-sender@gmail.com

# Gmail App Password (16 chars, NO spaces, NOT your real password).
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your16charapppass

# The clinic inbox that RECEIVES the notifications.
CLINIC_EMAIL=ashirwadclinicjpnagar@gmail.com

# ─── Google Sheets ───────────────────────────────────────────────────────────
# Path to the service-account JSON key downloaded from Google Cloud.
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# The ID from your sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
# IMPORTANT: open the sheet → Share → add the service-account email
# (xxx@xxx.iam.gserviceaccount.com) as an Editor, or appends will fail.
GOOGLE_SHEET_ID=your-google-sheet-id
